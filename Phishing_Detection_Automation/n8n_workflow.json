{
  "name": "Phishing Detection Pipeline",
  "nodes": [
    {
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "parameters": {
        "pollTimes": { "item": [{ "mode": "everyMinute" }] },
        "filters": { "labelIds": ["INBOX"], "readStatus": "unread" }
      },
      "position": [100, 300]
    },
    {
      "name": "Extract Email Data",
      "type": "n8n-nodes-base.function",
      "parameters": {
        "functionCode": "const email = items[0].json;\nreturn [{\n  json: {\n    message_id: email.id,\n    sender: email.from,\n    subject: email.subject,\n    body: email.text || email.html || '',\n    received_at: new Date().toISOString()\n  }\n}];"
      },
      "position": [300, 300]
    },
    {
      "name": "Send to Phishing Processor",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8001/webhook/email",
        "bodyParametersJson": "={{ $json }}",
        "options": { "response": { "response": { "fullResponse": true } } }
      },
      "position": [500, 300]
    },
    {
      "name": "Check Risk Level",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "string": [{
            "value1": "={{ $json.risk_level }}",
            "operation": "isNotEmpty"
          }],
          "number": [{
            "value1": "={{ $json.risk_score }}",
            "operation": "largerEqual",
            "value2": 50
          }]
        }
      },
      "position": [700, 300]
    },
    {
      "name": "Slack High Risk Alert",
      "type": "n8n-nodes-base.slack",
      "parameters": {
        "operation": "post",
        "channel": "#security-alerts",
        "text": "🚨 *Phishing Detected* — Score: {{ $json.risk_score }}/100\nFrom: {{ $json.sender }}\nSubject: {{ $json.subject }}\nVerdict: {{ $json.verdict }}"
      },
      "position": [900, 200]
    },
    {
      "name": "Log to Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "parameters": {
        "operation": "append",
        "spreadsheetId": "YOUR_SHEET_ID",
        "range": "Phishing Log!A:H",
        "dataMode": "autoMapInputData"
      },
      "position": [900, 400]
    }
  ],
  "connections": {
    "Gmail Trigger": { "main": [[{ "node": "Extract Email Data", "type": "main", "index": 0 }]] },
    "Extract Email Data": { "main": [[{ "node": "Send to Phishing Processor", "type": "main", "index": 0 }]] },
    "Send to Phishing Processor": { "main": [[{ "node": "Check Risk Level", "type": "main", "index": 0 }]] },
    "Check Risk Level": {
      "main": [
        [{ "node": "Slack High Risk Alert", "type": "main", "index": 0 }],
        [{ "node": "Log to Sheet", "type": "main", "index": 0 }]
      ]
    }
  }
}
