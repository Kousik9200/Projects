// LSASS Memory Dump via ProcDump
// Detects credential dumping from LSASS using ProcDump or similar tools
// MITRE ATT&CK: attack.credential_access, attack.t1003.001
DeviceProcessEvents
| where TimeGenerated >= ago(1h)
| where ((CommandLine contains "lsass")) or ((CommandLine contains "rundll32" and CommandLine contains "comsvcs.dll" and CommandLine contains "MiniDump"))
| project TimeGenerated, Computer, Account, CommandLine, InitiatingProcessFileName, EventID
| sort by TimeGenerated desc